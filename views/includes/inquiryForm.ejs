<section id="inquiry" class="py-5" style="background-color: var(--brand-light);">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div id="form-container" class="col-lg-8 text-center" data-aos="fade-up">
                <p class="uppercase-tracking text-gold mb-2">Get Started</p>
                <h2 class="mb-5 brand-font display-6">Initiate A Project</h2>
                
                <div class="card border-0 shadow-sm p-4 p-md-5 rounded-0 text-start bg-white mx-auto" style="max-width: 700px;">
                    <form id="contactForm" class="needs-validation" action="https://formspree.io/f/mqegodgo" method="POST" novalidate>
                        
                        <div class="row g-4">
                            <!-- Name -->
                            <div class="col-md-6">
                                <label class=" uppercase-tracking text-muted" style="font-size: 10px;">Full Name</label>
                                <input type="text" name="name" class="custom-input py-2" placeholder="e.g. John Doe" required>
                                <div class="invalid-feedback position-static mt-1">Please enter your full name.</div>
                            </div>
                            
                            <!-- Phone -->
                            <div class="col-md-6">
                                <label class=" uppercase-tracking text-muted" style="font-size: 10px;">Contact Number</label>
                                <div class="phone-wrapper w-100 m-0 p-0" style="border-bottom: 1px solid var(--text-muted);"> 
                                    <span class="phone-prefix">+91</span>
                                    <input type="tel" name="phone" id="phoneInput" class="phone-input-field" placeholder="98765 43210" pattern="[6-9][0-9]{9}" required>
                                </div>
                                <div class="invalid-feedback position-static mt-1">Enter a valid 10-digit number.</div>
                            </div>

                            <!-- Email -->
                            <div class="col-md-6">
                                <label class=" uppercase-tracking text-muted" style="font-size: 10px;">Email Address</label>
                                <input type="email" name="email" class="custom-input py-2" placeholder="name@domain.com" pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,4}$" required>
                                <div class="invalid-feedback position-static mt-1">Provide a valid email.</div>
                            </div>

                            <!-- Project Type -->
                            <div class="col-md-6">
                                <label class=" uppercase-tracking text-muted" style="font-size: 10px;">Type of Project</label>
                                <select name="construction_type" class="custom-input py-2" required>
                                    <option value="" selected disabled>Select Category</option>
                                    <option value="New Construction">New Construction</option>
                                    <option value="Renovation">Renovation</option>
                                    <option value="Interior Design">Interior Design</option>
                                    <option value="Commercial">Commercial Project</option>
                                </select>
                                <div class="invalid-feedback position-static mt-1">Select a category.</div>
                            </div>

                            <!-- Message -->
                            <div class="col-12 mt-4">
                                <label class=" uppercase-tracking text-muted" style="font-size: 10px;">Project Details</label>
                                <textarea name="message" class="custom-input py-2" rows="3" placeholder="Briefly describe your vision, location, and timeline..." required></textarea>
                                <div class="invalid-feedback position-static mt-1">Please provide project details.</div>
                            </div>

                            <!-- Submit -->
                            <div class="col-12 mt-5 text-center">
                                <button type="submit" id="submitBtn" class="btn btn-dark btn-lg w-100 rounded-0 py-3 uppercase-tracking tracking-wide">Submit Inquiry <i class="bi bi-arrow-right ms-2"></i></button>
                                <p class="small text-muted mt-3">We respect your privacy. No spam, ever.</p>
                            </div>
                        </div>
                        
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>